generator client {
  provider   = "prisma-client"
  output     = "../src/generated/prisma"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String  @id @default(cuid())
  telegramId   BigInt  @unique
  username     String?
  firstName    String?
  lastName     String?
  languageCode String? // ctx.from?.language_code

  // Last known context
  lastChatId    BigInt? // ctx.chat?.id (ostatni chat gdzie widzieliśmy usera)
  lastSeenAt    DateTime?
  lastMessageAt DateTime?

  //  app/business state
  verifiedAt DateTime?
  isBanned   Boolean   @default(false)
  bannedAt   DateTime?
  banReason  String?

  // Bot analytics / rate limiting
  messageCount Int @default(0)
  commandCount Int @default(0)

  // referral
  referralCode     String? @unique
  referredByUserId String?
  referredBy       User?   @relation("UserReferrals", fields: [referredByUserId], references: [id])
  referrals        User[]  @relation("UserReferrals")

  // identity
  identity UserIdentity?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isBanned])
  @@index([lastSeenAt])
  @@index([username])
  @@index([createdAt])
}

// ==========================================
// Cross-App Identity Models
// ==========================================

model UserIdentity {
  id              String   @id @default(cuid())
  telegramId      BigInt   @unique
  userId          String?  @unique
  user            User?    @relation(fields: [userId], references: [id])
  displayName     String?
  email           String?
  reputationScore Int      @default(0)
  firstSeenAt     DateTime @default(now())
  updatedAt       DateTime @updatedAt

  platformAccounts PlatformAccount[]

  @@index([telegramId])
  @@index([userId])
}

model PlatformAccount {
  id                  String    @id @default(cuid())
  identityId          String?
  identity            UserIdentity? @relation(fields: [identityId], references: [id])
  platform            String    // "telegram" | "discord" | "slack" | "whatsapp" | "custom"
  platformUserId      String    // Was telegramId (BigInt), now string for all platforms
  username            String?
  firstName           String?
  lastName            String?
  metadata            Json?     // Platform-specific: language_code, is_premium, avatar, etc.
  isBanned            Boolean   @default(false)
  bannedAt            DateTime?
  banReason           String?
  messageCount        Int       @default(0)
  commandCount        Int       @default(0)
  isVerified          Boolean   @default(false)
  verifiedAt          DateTime?
  lastSeenAt          DateTime?
  lastMessageAt       DateTime?
  lastCommunityId     String?
  referralCode        String?   @unique
  referredByAccountId String?
  referredBy          PlatformAccount? @relation("AccountReferrals", fields: [referredByAccountId], references: [id])
  referrals           PlatformAccount[] @relation("AccountReferrals")

  communityMemberships CommunityMember[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([platform, platformUserId])
  @@index([platform])
  @@index([isBanned])
  @@index([lastSeenAt])
  @@index([username])
  @@index([createdAt])
  @@index([identityId])
}

// ==========================================
// Community Models
// ==========================================

model Community {
  id                    String    @id @default(cuid())
  platform              String    // "telegram" | "discord" | etc.
  platformCommunityId   String    // Was chatId (BigInt), now string
  name                  String?
  type                  String?   // supergroup, guild, workspace, etc.
  memberCount           Int       @default(0)
  isActive              Boolean   @default(true)
  metadata              Json?     // Platform-specific: invite link, icon, etc.
  botInstanceId         String?
  botInstance           BotInstance? @relation(fields: [botInstanceId], references: [id])
  joinedAt              DateTime  @default(now())
  leftAt                DateTime?

  config                CommunityConfig?
  telegramConfig        CommunityTelegramConfig?
  discordConfig         CommunityDiscordConfig?
  members               CommunityMember[]
  analyticsSnapshots    CommunityAnalyticsSnapshot[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([platform, platformCommunityId])
  @@index([platform])
  @@index([isActive])
  @@index([botInstanceId])
}

model CommunityConfig {
  id                    String    @id @default(cuid())
  communityId           String    @unique
  community             Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  welcomeEnabled        Boolean   @default(true)
  welcomeMessage        String?
  rulesText             String?

  antiSpamEnabled       Boolean   @default(true)
  antiSpamAction        String    @default("delete")
  antiSpamMaxMessages   Int       @default(10)
  antiSpamWindowSeconds Int       @default(10)

  antiLinkEnabled       Boolean   @default(false)
  antiLinkAction        String    @default("delete")
  antiLinkWhitelist     String[]

  warnThresholdMute     Int       @default(3)
  warnThresholdBan      Int       @default(5)
  warnDecayDays         Int       @default(30)
  defaultMuteDurationS  Int       @default(3600)

  logChannelId          String?
  autoDeleteCommandsS   Int       @default(10)
  silentMode            Boolean   @default(false)

  keywordFiltersEnabled Boolean   @default(false)
  keywordFilters        String[]

  aiModerationEnabled   Boolean   @default(false)
  aiModerationAction    String    @default("delete")
  aiModThreshold        Float     @default(0.8)

  notificationEvents    String[]

  pipelineEnabled       Boolean   @default(false)
  pipelineDmTemplate    String?
  pipelineDeeplink      String?

  metadata              Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CommunityTelegramConfig {
  id                  String    @id @default(cuid())
  communityId         String    @unique
  community           Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  captchaEnabled      Boolean   @default(false)
  captchaMode         String    @default("button")
  captchaTimeoutS     Int       @default(60)

  quarantineEnabled   Boolean   @default(false)
  quarantineDurationS Int       @default(86400)

  slowModeDelay       Int       @default(0)
  forumTopicMgmt      Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CommunityDiscordConfig {
  id                String    @id @default(cuid())
  communityId       String    @unique
  community         Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  autoModRules      Json?
  verificationLevel String?
  defaultChannelId  String?
  modLogChannelId   String?
  welcomeChannelId  String?
  roleOnJoin        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CommunityMember {
  id                  String    @id @default(cuid())
  communityId         String
  community           Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  platformAccountId   String
  platformAccount     PlatformAccount @relation(fields: [platformAccountId], references: [id])
  role                String    @default("member")
  messageCount        Int       @default(0)
  joinedAt            DateTime  @default(now())
  warningCount        Int       @default(0)
  isMuted             Boolean   @default(false)
  muteExpiresAt       DateTime?
  isQuarantined       Boolean   @default(false)
  quarantineExpiresAt DateTime?
  lastSeenAt          DateTime  @default(now())
  metadata            Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([communityId, platformAccountId])
  @@index([communityId])
  @@index([platformAccountId])
  @@index([communityId, role])
  @@index([lastSeenAt])
}

// ==========================================
// Platform Connection Models
// ==========================================

model PlatformConnection {
  id                String    @id @default(cuid())
  platform          String    // "telegram" | "discord" | etc.
  name              String    // Display label
  connectionType    String    // "mtproto" | "bot_token" | "oauth" | "api_key"
  status            String    @default("inactive") // "active" | "inactive" | "error" | "authenticating"
  credentials       Json?     // Encrypted: session string, OAuth tokens, API keys
  metadata          Json?     // Platform-specific: phoneNumber, dcId, guildCount, scopes
  errorCount        Int       @default(0)
  lastErrorMessage  String?
  lastActiveAt      DateTime?
  botInstanceId     String?
  botInstance       BotInstance? @relation(fields: [botInstanceId], references: [id])

  logs              PlatformConnectionLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([platform])
  @@index([status])
  @@index([botInstanceId])
}

model PlatformConnectionLog {
  id           String   @id @default(cuid())
  connectionId String
  connection   PlatformConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  level        String   // "info" | "warn" | "error" | "debug"
  message      String
  details      Json?
  createdAt    DateTime @default(now())

  @@index([connectionId])
  @@index([createdAt])
  @@index([level])
}

// ==========================================
// Manager Bot Models
// ==========================================

model ManagedGroup {
  id       String  @id @default(cuid())
  chatId   BigInt  @unique
  title    String?
  isActive Boolean @default(true)
  joinedAt DateTime @default(now())
  leftAt   DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  config            GroupConfig?
  members           GroupMember[]
  warnings          Warning[]
  moderationLogs    ModerationLog[]
  scheduledMessages ScheduledMessage[]
  analyticsSnapshots GroupAnalyticsSnapshot[]

  @@index([chatId])
}

model GroupConfig {
  id      String       @id @default(cuid())
  groupId String       @unique
  group   ManagedGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  welcomeEnabled Boolean @default(true)
  welcomeMessage String?
  rulesText      String?

  warnThresholdMute    Int @default(3)
  warnThresholdBan     Int @default(5)
  warnDecayDays        Int @default(30)
  defaultMuteDurationS Int @default(3600)

  antiSpamEnabled       Boolean @default(true)
  antiSpamMaxMessages   Int     @default(10)
  antiSpamWindowSeconds Int     @default(10)

  antiLinkEnabled   Boolean  @default(false)
  antiLinkWhitelist String[]

  slowModeDelay Int @default(0)

  logChannelId        BigInt?
  autoDeleteCommandsS Int     @default(10)

  captchaEnabled  Boolean @default(false)
  captchaMode     String  @default("button")
  captchaTimeoutS Int     @default(60)

  quarantineEnabled    Boolean @default(false)
  quarantineDurationS  Int     @default(86400)

  silentMode Boolean @default(false)

  keywordFiltersEnabled Boolean  @default(false)
  keywordFilters        String[]

  aiModEnabled   Boolean @default(false)
  aiModThreshold Float   @default(0.8)

  notificationEvents String[]

  pipelineEnabled    Boolean @default(false)
  pipelineDmTemplate String?
  pipelineDeeplink   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GroupMember {
  id         String       @id @default(cuid())
  groupId    String
  group      ManagedGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  telegramId BigInt
  role       String       @default("member")
  joinedAt   DateTime     @default(now())
  messageCount Int        @default(0)
  lastSeenAt DateTime     @default(now())
  isQuarantined Boolean   @default(false)
  quarantineExpiresAt DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  warnings Warning[]

  @@unique([groupId, telegramId])
  @@index([groupId])
  @@index([telegramId])
  @@index([groupId, role])
  @@index([lastSeenAt])
}

model Warning {
  id        String       @id @default(cuid())
  groupId   String
  group     ManagedGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  memberId  String
  member    GroupMember   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  issuerId  BigInt
  reason    String?
  isActive  Boolean      @default(true)
  expiresAt DateTime?
  createdAt DateTime     @default(now())

  @@index([groupId])
  @@index([memberId])
  @@index([isActive, expiresAt])
  @@index([groupId, issuerId])
  @@index([groupId, isActive])
}

model ModerationLog {
  id        String       @id @default(cuid())
  groupId   String
  group     ManagedGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  action    String
  actorId   BigInt
  targetId  BigInt?
  reason    String?
  details   Json?
  automated Boolean      @default(false)
  createdAt DateTime     @default(now())

  @@index([groupId, createdAt])
  @@index([targetId])
  @@index([action])
  @@index([actorId])
  @@index([automated])
}

model ScheduledMessage {
  id        String       @id @default(cuid())
  groupId   String
  group     ManagedGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  chatId    BigInt
  text      String
  createdBy BigInt
  sendAt    DateTime
  sent      Boolean      @default(false)
  sentAt    DateTime?
  createdAt DateTime     @default(now())

  @@index([sendAt, sent])
  @@index([groupId])
  @@index([chatId])
  @@index([createdBy])
}

model GroupAnalyticsSnapshot {
  id              String       @id @default(cuid())
  groupId         String
  group           ManagedGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  date            DateTime     @db.Date
  memberCount     Int          @default(0)
  newMembers      Int          @default(0)
  leftMembers     Int          @default(0)
  messageCount    Int          @default(0)
  spamDetected    Int          @default(0)
  linksBlocked    Int          @default(0)
  warningsIssued  Int          @default(0)
  mutesIssued     Int          @default(0)
  bansIssued      Int          @default(0)
  deletedMessages Int          @default(0)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([groupId, date])
  @@index([groupId])
  @@index([date])
}

model CommunityAnalyticsSnapshot {
  id                String    @id @default(cuid())
  communityId       String
  community         Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  date              DateTime  @db.Date
  granularity       String    @default("DAY") // DAY | WEEK | MONTH
  memberCount       Int       @default(0)
  newMembers        Int       @default(0)
  leftMembers       Int       @default(0)
  messageCount      Int       @default(0)
  spamDetected      Int       @default(0)
  warningsIssued    Int       @default(0)
  moderationActions Int       @default(0)
  metadata          Json?     // linksBlocked, mutesIssued, bansIssued, deletedMessages

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([communityId, date, granularity])
  @@index([communityId])
  @@index([date])
}

model ReputationScore {
  id              String   @id @default(cuid())
  telegramId      BigInt   @unique
  totalScore      Int      @default(0)
  messageFactor   Int      @default(0)
  tenureFactor    Int      @default(0)
  warningPenalty  Int      @default(0)
  moderationBonus Int      @default(0)
  lastCalculated  DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([telegramId])
  @@index([totalScore])
}

model CrossPostTemplate {
  id           String   @id @default(cuid())
  name         String   @unique
  messageText  String
  targetChatIds BigInt[]
  isActive     Boolean  @default(true)
  createdBy    BigInt
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([name])
  @@index([isActive])
}

// ==========================================
// TG Client Models
// ==========================================

model BroadcastMessage {
  id            String   @id @default(cuid())
  status        String   @default("pending")
  text          String
  targetChatIds BigInt[]
  results       Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([status, createdAt])
}

model ClientLog {
  id        String   @id @default(cuid())
  level     String
  message   String
  details   Json?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([level])
}

model ClientSession {
  id            String   @id @default(cuid())
  sessionString String
  isActive      Boolean  @default(true)
  lastUsedAt    DateTime @default(now())
  phoneNumber   String?
  displayName   String?
  dcId          Int?
  sessionType   String   @default("user") // user | bot
  errorCount    Int      @default(0)
  lastError     String?
  lastErrorAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isActive])
  @@index([sessionType])
  @@index([isActive, sessionType])
}

// ==========================================
// Flow Builder Models
// ==========================================

model FlowDefinition {
  id          String   @id @default(cuid())
  name        String
  description String?
  nodesJson   Json     @default("[]")
  edgesJson   Json     @default("[]")
  transportConfig Json? // { platform?: 'telegram'|'discord', transport: 'mtproto'|'bot_api'|'discord_bot'|'auto', botInstanceId?, discordBotInstanceId? }
  platform    String   @default("telegram") // telegram | discord | cross_platform
  status      String   @default("draft") // draft | active | inactive
  version     Int      @default(1)

  folderId String?
  folder   FlowFolder? @relation(fields: [folderId], references: [id])

  executions FlowExecution[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([folderId])
}

model FlowFolder {
  id        String          @id @default(cuid())
  name      String
  parentId  String?
  parent    FlowFolder?     @relation("FolderTree", fields: [parentId], references: [id])
  children  FlowFolder[]    @relation("FolderTree")
  order     Int             @default(0)
  flows     FlowDefinition[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model FlowExecution {
  id          String   @id @default(cuid())
  flowId      String
  flow        FlowDefinition @relation(fields: [flowId], references: [id], onDelete: Cascade)
  status      String   @default("running") // running | completed | failed
  triggerData Json?
  nodeResults Json?
  error       String?
  startedAt   DateTime @default(now())
  completedAt DateTime?

  createdAt DateTime @default(now())

  @@index([flowId])
  @@index([status])
  @@index([flowId, status])
  @@index([flowId, createdAt])
  @@index([startedAt])
}

// ==========================================
// Bot Configuration Models
// ==========================================

model BotInstance {
  id          String   @id @default(cuid())
  name        String
  botToken    String
  botUsername String?
  platform    String   @default("telegram") // telegram | discord
  type        String   @default("standard") // standard | manager
  apiUrl      String?  // HTTP API URL for this bot instance (e.g. http://localhost:3001)
  metadata    Json?    // Platform-specific metadata (e.g. Discord guild IDs, intents)
  isActive    Boolean  @default(true)
  configVersion Int    @default(0)
  configHistory Json   @default("[]")

  commands     BotCommand[]
  responses    BotResponse[]
  menus        BotMenu[]
  communities  Community[]
  connections  PlatformConnection[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([botUsername])
  @@index([isActive])
  @@index([platform])
}

model BotCommand {
  id          String      @id @default(cuid())
  botId       String
  bot         BotInstance @relation(fields: [botId], references: [id], onDelete: Cascade)
  command     String
  description String?
  isEnabled   Boolean     @default(true)
  sortOrder   Int         @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([botId, command])
  @@index([botId])
}

model BotResponse {
  id       String      @id @default(cuid())
  botId    String
  bot      BotInstance @relation(fields: [botId], references: [id], onDelete: Cascade)
  key      String
  locale   String      @default("en")
  text     String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([botId, key, locale])
  @@index([botId])
}

model BotMenu {
  id     String      @id @default(cuid())
  botId  String
  bot    BotInstance @relation(fields: [botId], references: [id], onDelete: Cascade)
  name   String

  buttons BotMenuButton[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([botId, name])
  @@index([botId])
}

model BotMenuButton {
  id       String  @id @default(cuid())
  menuId   String
  menu     BotMenu @relation(fields: [menuId], references: [id], onDelete: Cascade)
  label    String
  action   String
  row      Int     @default(0)
  col      Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([menuId])
}

// ==========================================
// Flow Versioning Models
// ==========================================

model FlowVersion {
  id         String   @id @default(cuid())
  flowId     String
  version    Int
  nodesJson  Json
  edgesJson  Json
  createdBy  String?
  createdAt  DateTime @default(now())

  @@unique([flowId, version])
  @@index([flowId])
}

// ==========================================
// Flow Context & Events
// ==========================================

model UserFlowContext {
  id             String   @id @default(cuid())
  platformUserId String
  platform       String   // "telegram" | "discord"
  key            String
  value          Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([platformUserId, platform, key])
  @@index([platformUserId, platform])
}

model FlowEvent {
  id                String   @id @default(cuid())
  eventName         String
  payload           Json
  sourceFlowId      String
  sourceExecutionId String
  createdAt         DateTime @default(now())
  expiresAt         DateTime @default(dbgenerated("NOW() + INTERVAL '30 days'"))

  @@index([eventName])
  @@index([sourceFlowId])
  @@index([expiresAt])
}

// ==========================================
// Webhook Ingress Models
// ==========================================

model WebhookEndpoint {
  id          String   @id @default(cuid())
  name        String
  token       String   @unique @default(cuid())
  flowId      String?
  isActive    Boolean  @default(true)
  lastCalledAt DateTime?
  callCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([token])
  @@index([flowId])
}
