generator client {
  provider   = "prisma-client"
  output     = "../src/generated/prisma"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String  @id @default(cuid())
  telegramId   BigInt  @unique
  username     String?
  firstName    String?
  lastName     String?
  languageCode String? // ctx.from?.language_code

  // Last known context
  lastChatId    BigInt? // ctx.chat?.id (ostatni chat gdzie widzieliśmy usera)
  lastSeenAt    DateTime?
  lastMessageAt DateTime?

  //  app/business state
  verifiedAt DateTime?
  isBanned   Boolean   @default(false)
  bannedAt   DateTime?
  banReason  String?

  // Bot analytics / rate limiting
  messageCount Int @default(0)
  commandCount Int @default(0)

  // referral
  referralCode     String? @unique
  referredByUserId String?
  referredBy       User?   @relation("UserReferrals", fields: [referredByUserId], references: [id])
  referrals        User[]  @relation("UserReferrals")

  // cart
  cart Cart?

  // identity
  identity UserIdentity?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isBanned])
  @@index([lastSeenAt])
  @@index([username])
  @@index([createdAt])
}

// Category - hierarchical categories for products
model Category {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  parentId  String?
  parent    Category? @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryHierarchy")
  order     Int       @default(0)
  isActive  Boolean   @default(true)
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([slug])
  @@index([isActive])
  @@index([order])
}

// Product
model Product {
  id             String    @id @default(cuid())
  name           String
  description    String?
  slug           String    @unique
  price          Decimal   @db.Decimal(10, 2)
  compareAtPrice Decimal?  @db.Decimal(10, 2)
  categoryId     String
  category       Category  @relation(fields: [categoryId], references: [id])
  images         String[]
  thumbnail      String?
  sku            String?   @unique
  stock          Int       @default(0)
  isActive       Boolean   @default(true)
  isFeatured     Boolean   @default(false)
  cartItems      CartItem[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([categoryId])
  @@index([slug])
  @@index([isActive])
  @@index([sku])
  @@index([stock])
  @@index([categoryId, isActive])
  @@index([isFeatured])
}

// Cart - one per user
model Cart {
  id         String     @id @default(cuid())
  userId     String     @unique
  user       User       @relation(fields: [userId], references: [id])
  items      CartItem[]
  totalItems Int        @default(0)
  totalAmount Decimal   @default(0) @db.Decimal(10, 2)
  updatedAt  DateTime   @updatedAt

  @@index([userId])
}

// CartItem
model CartItem {
  id           String   @id @default(cuid())
  cartId       String
  cart         Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId    String
  product      Product  @relation(fields: [productId], references: [id])
  quantity     Int      @default(1)
  productName  String
  productPrice Decimal  @db.Decimal(10, 2)
  productImage String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([cartId, productId])
  @@index([cartId])
  @@index([productId])
}

// ==========================================
// Cross-App Identity Models
// ==========================================

model UserIdentity {
  id              String   @id @default(cuid())
  telegramId      BigInt   @unique
  userId          String?  @unique
  user            User?    @relation(fields: [userId], references: [id])
  reputationScore Int      @default(0)
  firstSeenAt     DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([telegramId])
  @@index([userId])
}

// ==========================================
// Manager Bot Models
// ==========================================

model ManagedGroup {
  id       String  @id @default(cuid())
  chatId   BigInt  @unique
  title    String?
  isActive Boolean @default(true)
  joinedAt DateTime @default(now())
  leftAt   DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  config            GroupConfig?
  members           GroupMember[]
  warnings          Warning[]
  moderationLogs    ModerationLog[]
  scheduledMessages ScheduledMessage[]
  analyticsSnapshots GroupAnalyticsSnapshot[]

  @@index([chatId])
}

model GroupConfig {
  id      String       @id @default(cuid())
  groupId String       @unique
  group   ManagedGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  welcomeEnabled Boolean @default(true)
  welcomeMessage String?
  rulesText      String?

  warnThresholdMute    Int @default(3)
  warnThresholdBan     Int @default(5)
  warnDecayDays        Int @default(30)
  defaultMuteDurationS Int @default(3600)

  antiSpamEnabled       Boolean @default(true)
  antiSpamMaxMessages   Int     @default(10)
  antiSpamWindowSeconds Int     @default(10)

  antiLinkEnabled   Boolean  @default(false)
  antiLinkWhitelist String[]

  slowModeDelay Int @default(0)

  logChannelId        BigInt?
  autoDeleteCommandsS Int     @default(10)

  captchaEnabled  Boolean @default(false)
  captchaMode     String  @default("button")
  captchaTimeoutS Int     @default(60)

  quarantineEnabled    Boolean @default(false)
  quarantineDurationS  Int     @default(86400)

  silentMode Boolean @default(false)

  keywordFiltersEnabled Boolean  @default(false)
  keywordFilters        String[]

  aiModEnabled   Boolean @default(false)
  aiModThreshold Float   @default(0.8)

  notificationEvents String[]

  pipelineEnabled    Boolean @default(false)
  pipelineDmTemplate String?
  pipelineDeeplink   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GroupMember {
  id         String       @id @default(cuid())
  groupId    String
  group      ManagedGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  telegramId BigInt
  role       String       @default("member")
  joinedAt   DateTime     @default(now())
  messageCount Int        @default(0)
  lastSeenAt DateTime     @default(now())
  isQuarantined Boolean   @default(false)
  quarantineExpiresAt DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  warnings Warning[]

  @@unique([groupId, telegramId])
  @@index([groupId])
  @@index([telegramId])
  @@index([groupId, role])
  @@index([lastSeenAt])
}

model Warning {
  id        String       @id @default(cuid())
  groupId   String
  group     ManagedGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  memberId  String
  member    GroupMember   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  issuerId  BigInt
  reason    String?
  isActive  Boolean      @default(true)
  expiresAt DateTime?
  createdAt DateTime     @default(now())

  @@index([groupId])
  @@index([memberId])
  @@index([isActive, expiresAt])
  @@index([groupId, issuerId])
  @@index([groupId, isActive])
}

model ModerationLog {
  id        String       @id @default(cuid())
  groupId   String
  group     ManagedGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  action    String
  actorId   BigInt
  targetId  BigInt?
  reason    String?
  details   Json?
  automated Boolean      @default(false)
  createdAt DateTime     @default(now())

  @@index([groupId, createdAt])
  @@index([targetId])
  @@index([action])
  @@index([actorId])
  @@index([automated])
}

model ScheduledMessage {
  id        String       @id @default(cuid())
  groupId   String
  group     ManagedGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  chatId    BigInt
  text      String
  createdBy BigInt
  sendAt    DateTime
  sent      Boolean      @default(false)
  sentAt    DateTime?
  createdAt DateTime     @default(now())

  @@index([sendAt, sent])
  @@index([groupId])
  @@index([chatId])
  @@index([createdBy])
}

model GroupAnalyticsSnapshot {
  id              String       @id @default(cuid())
  groupId         String
  group           ManagedGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  date            DateTime     @db.Date
  memberCount     Int          @default(0)
  newMembers      Int          @default(0)
  leftMembers     Int          @default(0)
  messageCount    Int          @default(0)
  spamDetected    Int          @default(0)
  linksBlocked    Int          @default(0)
  warningsIssued  Int          @default(0)
  mutesIssued     Int          @default(0)
  bansIssued      Int          @default(0)
  deletedMessages Int          @default(0)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([groupId, date])
  @@index([groupId])
  @@index([date])
}

model ReputationScore {
  id              String   @id @default(cuid())
  telegramId      BigInt   @unique
  totalScore      Int      @default(0)
  messageFactor   Int      @default(0)
  tenureFactor    Int      @default(0)
  warningPenalty  Int      @default(0)
  moderationBonus Int      @default(0)
  lastCalculated  DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([telegramId])
  @@index([totalScore])
}

model CrossPostTemplate {
  id           String   @id @default(cuid())
  name         String   @unique
  messageText  String
  targetChatIds BigInt[]
  isActive     Boolean  @default(true)
  createdBy    BigInt
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([name])
  @@index([isActive])
}

// ==========================================
// TG Client Models
// ==========================================

model BroadcastMessage {
  id            String   @id @default(cuid())
  status        String   @default("pending")
  text          String
  targetChatIds BigInt[]
  results       Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([status, createdAt])
}

model OrderEvent {
  id            String   @id @default(cuid())
  eventType     String
  orderData     Json
  targetChatIds BigInt[]
  jobId         String?
  processed     Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@index([processed])
  @@index([eventType])
  @@index([createdAt])
  @@index([processed, createdAt])
}

model ClientLog {
  id        String   @id @default(cuid())
  level     String
  message   String
  details   Json?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([level])
}

model ClientSession {
  id            String   @id @default(cuid())
  sessionString String
  isActive      Boolean  @default(true)
  lastUsedAt    DateTime @default(now())
  phoneNumber   String?
  displayName   String?
  dcId          Int?
  sessionType   String   @default("user") // user | bot
  errorCount    Int      @default(0)
  lastError     String?
  lastErrorAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isActive])
  @@index([sessionType])
  @@index([isActive, sessionType])
}

// ==========================================
// Flow Builder Models
// ==========================================

model FlowDefinition {
  id          String   @id @default(cuid())
  name        String
  description String?
  nodesJson   Json     @default("[]")
  edgesJson   Json     @default("[]")
  status      String   @default("draft") // draft | active | inactive
  version     Int      @default(1)

  executions FlowExecution[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

model FlowExecution {
  id          String   @id @default(cuid())
  flowId      String
  flow        FlowDefinition @relation(fields: [flowId], references: [id], onDelete: Cascade)
  status      String   @default("running") // running | completed | failed
  triggerData Json?
  nodeResults Json?
  error       String?
  startedAt   DateTime @default(now())
  completedAt DateTime?

  createdAt DateTime @default(now())

  @@index([flowId])
  @@index([status])
  @@index([flowId, status])
  @@index([flowId, createdAt])
  @@index([startedAt])
}

// ==========================================
// Bot Configuration Models
// ==========================================

model BotInstance {
  id          String   @id @default(cuid())
  name        String
  botToken    String
  botUsername String?
  type        String   @default("standard") // standard | manager
  apiUrl      String?  // HTTP API URL for this bot instance (e.g. http://localhost:3001)
  isActive    Boolean  @default(true)
  configVersion Int    @default(0)
  configHistory Json   @default("[]")

  commands  BotCommand[]
  responses BotResponse[]
  menus     BotMenu[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([botUsername])
  @@index([isActive])
}

model BotCommand {
  id          String      @id @default(cuid())
  botId       String
  bot         BotInstance @relation(fields: [botId], references: [id], onDelete: Cascade)
  command     String
  description String?
  isEnabled   Boolean     @default(true)
  sortOrder   Int         @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([botId, command])
  @@index([botId])
}

model BotResponse {
  id       String      @id @default(cuid())
  botId    String
  bot      BotInstance @relation(fields: [botId], references: [id], onDelete: Cascade)
  key      String
  locale   String      @default("en")
  text     String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([botId, key, locale])
  @@index([botId])
}

model BotMenu {
  id     String      @id @default(cuid())
  botId  String
  bot    BotInstance @relation(fields: [botId], references: [id], onDelete: Cascade)
  name   String

  buttons BotMenuButton[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([botId, name])
  @@index([botId])
}

model BotMenuButton {
  id       String  @id @default(cuid())
  menuId   String
  menu     BotMenu @relation(fields: [menuId], references: [id], onDelete: Cascade)
  label    String
  action   String
  row      Int     @default(0)
  col      Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([menuId])
}

// ==========================================
// Flow Versioning Models
// ==========================================

model FlowVersion {
  id         String   @id @default(cuid())
  flowId     String
  version    Int
  nodesJson  Json
  edgesJson  Json
  createdBy  String?
  createdAt  DateTime @default(now())

  @@unique([flowId, version])
  @@index([flowId])
}

// ==========================================
// Webhook Ingress Models
// ==========================================

model WebhookEndpoint {
  id          String   @id @default(cuid())
  name        String
  token       String   @unique @default(cuid())
  flowId      String?
  isActive    Boolean  @default(true)
  lastCalledAt DateTime?
  callCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([token])
  @@index([flowId])
}
