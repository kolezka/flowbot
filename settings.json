{
  "env": {
    "CLAUDE_PACKAGE_MANAGER": "pnpm",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "mcp__plugin_context7_context7__resolve-library-id",
      "WebSearch",
      "mcp__web-reader__webReader",
      "mcp__web-search-prime__webSearchPrime",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(pnpm prisma generate:*)",
      "Bash(pnpm prisma migrate dev:*)",
      "Bash(pnpm dev:*)",
      "Bash(pkill:*)",
      "Bash(lsof:*)",
      "Bash(xargs kill:*)",
      "Bash(curl:*)",
      "Bash(npx:*)",
      "Bash(pnpm prisma:generate:*)",
      "Bash(pnpm build:*)",
      "Bash(pnpm add:*)",
      "Bash(pnpm --filter @flowbot/frontend add:*)",
      "Bash(pnpm:*)",
      "Bash(DATABASE_URL=\"postgresql://postgres:postgres@localhost:5432/flowbot_db?schema=public\" npx prisma migrate dev:*)",
      "Bash(wc:*)",
      "Bash(grep:*)",
      "Bash(xargs:*)"
