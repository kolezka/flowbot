{
  "name": "@flowbot/whatsapp-bot",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "engines": { "node": ">=20.0.0" },
  "scripts": {
    "lint": "eslint .",
    "format": "eslint . --fix",
    "typecheck": "tsc",
    "build": "tsc --noEmit false",
    "dev": "tsx watch ./src/main.ts",
    "start": "tsx ./src/main.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@flowbot/whatsapp-transport": "workspace:*",
    "@flowbot/db": "workspace:*",
    "@hono/node-server": "1.14.2",
    "hono": "4.10.3",
    "pino": "9.9.0",
    "pino-pretty": "13.0.0",
    "tsx": "4.20.4",
    "valibot": "0.42.1"
  },
  "devDependencies": {
    "@antfu/eslint-config": "4.12.0",
    "@types/node": "^22.15.21",
    "eslint": "^9.27.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.1"
  }
}
